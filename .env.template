# ════════════════════════════════════════════════════════════════════════════════
# SemSaver — Environment Configuration Template
# Copy this file to backend/.env, then fill in all required values.
# NEVER commit .env to version control.
# ════════════════════════════════════════════════════════════════════════════════

# ── LLM: Groq (primary — fast, free tier) ────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ── LLM: Gemini (fallback — used only if GROQ_API_KEY is empty) ──────────────
GEMINI_API_KEY=your_gemini_api_key_here
GENERATION_MODEL=gemini-2.0-flash

# ── Neo4j ─────────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password_here

# ── Storage ───────────────────────────────────────────────────────────────────
UPLOAD_DIR=../uploads
FAISS_INDEX_PATH=faiss_index.bin
FAISS_META_PATH=faiss_meta.json

# ── Local embedding model (CPU inference, no API key needed) ──────────────────
# Recommended: BAAI/bge-small-en-v1.5 (fast, small, good quality)
# Alternative: jinaai/jina-embeddings-v3 (better quality, slower, needs trust_remote_code)
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# ── KeyBERT backbone (local, no API key needed) ───────────────────────────────
KEYWORD_MODEL=all-MiniLM-L6-v2

# ── Pipeline tuning ───────────────────────────────────────────────────────────
CHUNK_SIZE=600
CHUNK_OVERLAP=100
TOP_K_KEYWORDS=10
TOP_K_VECTOR=5

# ── Security ──────────────────────────────────────────────────────────────────
# API key required in X-Api-Key header for /upload and /chat endpoints.
# Leave blank to disable authentication (development only — NOT for production).
API_KEY=change-me-to-a-strong-random-secret

# JWT secret — reserved for future stateful session support.
JWT_SECRET=change-me-to-a-strong-random-secret

# Maximum file upload size in bytes (default: 10 MB = 10485760).
MAX_FILE_SIZE=10485760

# Rate limits (slowapi format: "N/period" where period = second|minute|hour).
RATE_LIMIT_UPLOAD=5/minute
RATE_LIMIT_CHAT=30/minute

# Comma-separated list of allowed CORS origins.
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
